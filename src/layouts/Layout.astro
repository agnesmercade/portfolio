---
import '../styles/global.css';

export interface Props {
  title?: string;
}

const { title = "Agnès Mercadé" } = Astro.props;
const path = Astro.url.pathname;

const CDN = "https://images.squarespace-cdn.com/content/v1/69788340c4a614347d63a918/";
const logo = CDN + "b117f40f-1347-4dd4-98f8-2d3903a148a9/logo+agnes.png?format=300w";
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500&display=swap" rel="stylesheet" />
</head>
<body>

  <header class="site-header" id="site-header">
    <!-- Left: logo + primary nav -->
    <div class="header-left">
      <a href="/" class="header-logo" aria-label="Home">
        <img src={logo} alt="Agnès Mercadé" width="220" height="50" />
      </a>
      <nav aria-label="Main" class="header-primary-nav">
        <a href="/projects" class={path === '/projects' ? 'active' : ''}>Projects</a>
        <a href="/about" class={path === '/about' ? 'active' : ''}>About</a>
      </nav>
    </div>

    <!-- Right: social + language -->
    <div class="header-right">
      <a href="https://www.instagram.com/by.agnesmercade/" target="_blank" rel="noopener" aria-label="Instagram" class="nav-icon">
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
        </svg>
      </a>
      <a href="http://www.linkedin.com/in/agnesmercade" target="_blank" rel="noopener" aria-label="LinkedIn" class="nav-icon">
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
      </a>
      <span class="lang-toggle">Español</span>
    </div>

    <button class="hamburger" id="hamburger" aria-label="Open menu">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </header>

  <nav class="mobile-nav" id="mobile-nav" aria-label="Mobile menu">
    <button class="mobile-nav-close" id="mobile-nav-close" aria-label="Close menu">✕</button>
    <a href="/projects">Projects</a>
    <a href="/about">About</a>
    <a href="https://www.instagram.com/by.agnesmercade/" target="_blank" rel="noopener">Instagram</a>
    <a href="http://www.linkedin.com/in/agnesmercade" target="_blank" rel="noopener">LinkedIn</a>
    <span class="lang-toggle">Español</span>
  </nav>

  <main>
    <slot />
  </main>

  <footer class="site-footer"></footer>

</body>
</html>

<script>
  const header = document.getElementById('site-header');
  const hamburger = document.getElementById('hamburger');
  const mobileNav = document.getElementById('mobile-nav');
  const closeBtn = document.getElementById('mobile-nav-close');

  window.addEventListener('scroll', () => {
    header?.classList.toggle('scrolled', window.scrollY > 10);
  }, { passive: true });

  hamburger?.addEventListener('click', () => {
    mobileNav?.classList.add('open');
    document.body.style.overflow = 'hidden';
  });

  const closeMobileNav = () => {
    mobileNav?.classList.remove('open');
    document.body.style.overflow = '';
  };

  closeBtn?.addEventListener('click', closeMobileNav);
  mobileNav?.querySelectorAll('a').forEach(a => a.addEventListener('click', closeMobileNav));
</script>

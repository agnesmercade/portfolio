---
import Layout from '../layouts/Layout.astro';
import { asset } from '../utils/url';

// Top-right: wide landscape screenshot
const imgWide = asset('/images/between/wide.webp');

// Gallery: two rows of three portrait images
const row1 = [
  asset('/images/between/photo-1.jpg'),
  asset('/images/between/photo-2.jpg'),
  asset('/images/between/photo-3.jpg'),
];
const row2 = [
  asset('/images/between/photo-4.jpg'),
  asset('/images/between/photo-5.jpg'),
  asset('/images/between/photo-6.jpg'),
];
---

<Layout title="Between the Sheets — Agnès Mercadé">
  <div class="bts-page">

    <!-- ── Top: text left │ wide screenshot right ── -->
    <div class="bts-top">
      <div class="bts-text">
        <h1 class="project-title">Between the sheets</h1>
        <div class="bts-desc">
          <p data-i18n="bts.p1">An ongoing photographic series set within Barcelona's interior courtyards.</p>
          <p data-i18n="bts.p2">Through laundry lines, hanging sheets, and shifting light, the images linger on quiet traces of everyday life hidden inside the city's blocks. The series explores the subtle rhythms of these spaces where architecture, light, and domestic details create an intimate, almost private atmosphere.</p>
        </div>
      </div>
      <div class="bts-screenshot">
        <img src={imgWide} alt="" loading="lazy" />
      </div>
    </div>

    <!-- ── Gallery: 3-column, 2 rows ── -->
    <div class="bts-gallery">
      {[...row1, ...row2].map(src => (
        <img src={src} alt="" loading="lazy" />
      ))}
    </div>

  </div>
</Layout>

<style>
  .bts-page {
    padding: calc(var(--nav-height) + 3rem) var(--gutter) 6rem;
    max-width: var(--site-max);
    margin: 0 auto;
  }

  /* ── Top section: text left, screenshot right ── */
  .bts-top {
    display: grid;
    grid-template-columns: 11fr 12fr;
    gap: 4vw;
    align-items: start;
    margin-bottom: 6rem;
  }

.bts-desc {
    font-size: 14px;
    line-height: 1.8;
    color: var(--gray);
    text-align: justify;
  }

  .bts-desc p + p { margin-top: 1rem; }

  /* Screenshot pushed down to align below the h1 */
  .bts-screenshot {
    padding-top: 4rem;
  }

  .bts-screenshot img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* ── Gallery: 3 equal columns, 11px gap ── */
  .bts-gallery {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: min(4vw, 64px);
    align-items: start;
  }

  .bts-gallery img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* ── Mobile ── */
  @media (max-width: 767px) {
    .bts-top {
      grid-template-columns: 1fr;
      gap: 2rem;
      margin-bottom: 2rem;
    }

    .bts-screenshot { padding-top: 0; }

    .bts-gallery {
      grid-template-columns: 1fr;
      gap: 8px;
    }
  }
</style>

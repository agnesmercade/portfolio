---
import Layout from '../layouts/Layout.astro';

const CDN = "https://images.squarespace-cdn.com/content/v1/69788340c4a614347d63a918/";

const projects = [
  {
    title: "01_Santander",
    discipline: "photo",
    href: "/santander",
    thumb: CDN + "4d7bb668-f145-4b96-b6e0-3f3c26fd59ba/A031342-R1-24-25A.jpg?format=2500w",
  },
  {
    title: "02_@by.agnesmercade",
    discipline: "hybrid",
    href: "/byagnesmercade",
    thumb: CDN + "8598cb0c-46b7-402b-aeed-34b6bd3a0599/grid1_2026-05-21+a+las+19.22.34.png?format=2500w",
  },
  {
    title: "03_Echoes of Comfort",
    discipline: "photo",
    href: "/echoes-of-comfort",
    thumb: CDN + "a2432303-900b-43b7-a383-006bbf200aa2/llabiafinal-002.jpg?format=2500w",
  },
  {
    title: "04_Publicis Commerce",
    discipline: "digital marketing",
    href: "/publicis-commerce",
    thumb: CDN + "26dd7b14-0973-4d42-b84e-ebdfeb81fe99/publicis_commerce-80.jpg?format=2500w",
  },
  {
    title: "05_60 Seconds",
    discipline: "video",
    href: "/60seconds",
    thumb: CDN + "09f813f6-fb79-4450-bc3d-d95f4cd19031/Captura+de+pantalla+2026-02-02+a+las+11.17.38.png?format=2500w",
  },
  {
    title: "06_Between the Sheets",
    discipline: "photo",
    href: "/between-the-sheets",
    thumb: CDN + "fd998fb6-7d1c-4069-af94-947fe409efd0/Captura+de+pantalla+2026-03-14+a+las+19.24.00.png?format=2500w",
  },
];
---

<Layout title="Projects — Agnès Mercadé">
  <section class="projects-index">
    <div class="projects-index-bg" id="projectsBg"></div>
    <ul class="projects-stack">
      {projects.map(p => (
        <li>
          <a
            href={p.href}
            class="project-stack-link"
            data-thumb={p.thumb}
          >
            {p.title}<span class="project-discipline"> — {p.discipline}</span>
          </a>
        </li>
      ))}
    </ul>
  </section>
</Layout>

<style>
  .project-discipline {
    font-size: 0.55em;
    font-weight: 300;
    opacity: 0.55;
    letter-spacing: 0.03em;
    vertical-align: middle;
  }
</style>

<script>
  const bg = document.getElementById('projectsBg');
  const links = document.querySelectorAll<HTMLAnchorElement>('.project-stack-link');
  let timeout: ReturnType<typeof setTimeout>;

  links.forEach(link => {
    link.addEventListener('mouseenter', () => {
      clearTimeout(timeout);
      if (bg) {
        bg.style.backgroundImage = `url(${link.dataset.thumb})`;
        bg.classList.add('visible');
      }
    });
    link.addEventListener('mouseleave', () => {
      timeout = setTimeout(() => {
        bg?.classList.remove('visible');
      }, 200);
    });
  });
</script>

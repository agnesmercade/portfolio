---
import Layout from '../layouts/Layout.astro';
import { asset } from '../utils/url';

const projects = [
  {
    title: "01_Santander",
    discipline: "photo",
    discKey: "disc.photo",
    href: asset('/santander'),
    thumb: asset('/images/santander/carousel-1.jpg'),
  },
  {
    title: "02_@by.agnesmercade",
    discipline: "hybrid",
    discKey: "disc.hybrid",
    href: asset('/byagnesmercade'),
    thumb: asset('/images/byagnes/grid-1.webp'),
  },
  {
    title: "03_Echoes of Comfort",
    discipline: "photo",
    discKey: "disc.photo",
    href: asset('/echoes-of-comfort'),
    thumb: asset('/images/echoes/02.jpg'),
  },
  {
    title: "04_Publicis Commerce",
    discipline: "digital marketing",
    discKey: "disc.digital",
    href: asset('/publicis-commerce'),
    thumb: asset('/images/projects/thumb-publicis.jpg'),
  },
  {
    title: "05_60 Seconds",
    discipline: "video",
    discKey: "disc.video",
    href: asset('/60seconds'),
    thumb: asset('/images/projects/thumb-60seconds.webp'),
  },
  {
    title: "06_Between the Sheets",
    discipline: "photo",
    discKey: "disc.photo",
    href: asset('/between-the-sheets'),
    thumb: asset('/images/projects/thumb-between.webp'),
  },
];
---

<Layout title="Projects — Agnès Mercadé" titleKey="title.projects">
  <section class="projects-index">
    <div class="projects-index-bg" id="projectsBg"></div>
    <ul class="projects-stack">
      {projects.map(p => (
        <li>
          <a
            href={p.href}
            class="project-stack-link"
            data-thumb={p.thumb}
          >
            {p.title}<span class="project-discipline" data-i18n={p.discKey}> — {p.discipline}</span>
          </a>
        </li>
      ))}
    </ul>
  </section>
</Layout>

<style>
  .project-discipline {
    font-size: 0.55em;
    font-weight: 300;
    opacity: 0.55;
    letter-spacing: 0.03em;
    vertical-align: middle;
  }
</style>

<script>
  const bg = document.getElementById('projectsBg');
  const links = document.querySelectorAll<HTMLAnchorElement>('.project-stack-link');
  let timeout: ReturnType<typeof setTimeout>;

  links.forEach(link => {
    link.addEventListener('mouseenter', () => {
      clearTimeout(timeout);
      if (bg) {
        bg.style.backgroundImage = `url(${link.dataset.thumb})`;
        bg.classList.add('visible');
      }
    });
    link.addEventListener('mouseleave', () => {
      timeout = setTimeout(() => {
        bg?.classList.remove('visible');
      }, 200);
    });
  });
</script>

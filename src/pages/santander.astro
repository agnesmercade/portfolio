---
import Layout from '../layouts/Layout.astro';
import { asset } from '../utils/url';

const slides = [
  asset('/images/santander/carousel-1.jpg'),
  asset('/images/santander/carousel-2.jpg'),
  asset('/images/santander/carousel-3.jpg'),
  asset('/images/santander/carousel-4.jpg'),
];

// gallery-01 goes in the middle section info column
const heroImage = { src: asset('/images/santander/gallery-01.jpg'), w: 960, h: 1440 };

// gallery-02 onwards go in the masonry grid
const galleryImages = [
  { src: asset('/images/santander/gallery-05.jpg'), w: 960, h: 1440 },
  { src: asset('/images/santander/gallery-03.jpg'), w: 960, h: 640  },
  { src: asset('/images/santander/gallery-07.jpg'), w: 960, h: 1440 },
  { src: asset('/images/santander/gallery-02.jpg'), w: 960, h: 643  },
  { src: asset('/images/santander/gallery-06.jpg'), w: 960, h: 1440 },
  { src: asset('/images/santander/gallery-04.jpg'), w: 960, h: 640  },
  { src: asset('/images/santander/gallery-08.jpg'), w: 960, h: 644  },
  { src: asset('/images/santander/gallery-09.jpg'), w: 960, h: 1431 },
  { src: asset('/images/santander/gallery-10.jpg'), w: 960, h: 644  },
  { src: asset('/images/santander/gallery-11.jpg'), w: 960, h: 1431 },
  { src: asset('/images/santander/gallery-12.jpg'), w: 960, h: 1440 },
  { src: asset('/images/santander/gallery-13.jpg'), w: 960, h: 640  },
];
---

<Layout title="Santander — Agnès Mercadé">

  <!-- TOP: full-width carousel sits directly below the fixed nav -->
  <div class="san-top">
    <div class="san-reel" id="sanReel">
      <div class="san-track" id="sanTrack">
        <div class="san-slide"><img src={slides[slides.length - 2]} alt="" /></div>
        <div class="san-slide"><img src={slides[slides.length - 1]} alt="" /></div>
        {slides.map(src => (
          <div class="san-slide"><img src={src} alt="" /></div>
        ))}
        <div class="san-slide"><img src={slides[0]} alt="" /></div>
        <div class="san-slide"><img src={slides[1]} alt="" /></div>
      </div>
      <button class="san-btn san-prev" id="sanPrev" aria-label="Previous">&#8249;</button>
      <button class="san-btn san-next" id="sanNext" aria-label="Next">&#8250;</button>
    </div>
  </div>

  <!-- MIDDLE: title | description | first image -->
  <div class="san-mid">
    <div class="san-mid-left">
      <h1 class="project-title">Santander</h1>
    </div>
    <div class="san-mid-center">
      <p data-i18n="san.p1">A personal project shot on 35mm film in Santander, combining color and black and white.</p>
      <p data-i18n="san.p2">
        The black and white images come from an intentional experiment during development: the film
        was treated as if it had been shot at a lower ISO, pushing contrast and density further.
        The result is a more graphic and defined look, where light and shadow take the lead.
      </p>
      <p data-i18n="san.p3">
        Color photographs work differently, paying attention to subtle shifts in light, atmosphere,
        and balance within the frame.
      </p>
      <p data-i18n="san.p4">
        Across both formats, the project is driven by visual intuition and a strong sense of
        composition, rather than a fixed narrative.
      </p>
    </div>
    <div class="san-mid-right">
      <img
        src={heroImage.src}
        alt=""
        width={heroImage.w}
        height={heroImage.h}
        loading="lazy"
      />
    </div>
  </div>

  <!-- BOTTOM: masonry grid of remaining images -->
  <div class="san-gallery-outer">
    <div class="san-masonry" id="sanMasonry">
      {galleryImages.map(({ src, w, h }) => (
        <img src={src} alt="" loading="lazy" width={w} height={h} />
      ))}
    </div>
  </div>

</Layout>

<style>
  /* ── TOP: carousel ── */
  .san-top {
    padding-top: var(--nav-height);
    background: #000;
  }

  .san-reel {
    position: relative;
    overflow: hidden;
    width: 100%;
    height: clamp(280px, 60vh, 640px);
  }

  .san-track {
    display: flex;
    height: 100%;
    transition: transform 0.5s ease;
    will-change: transform;
  }

  .san-slide {
    flex-shrink: 0;
    height: 100%;
  }

  .san-slide img {
    height: 100%;
    width: auto;
    display: block;
  }

  .san-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(0, 0, 0, 0.3);
    border: none;
    color: #fff;
    font-size: 2.5rem;
    line-height: 1;
    cursor: pointer;
    padding: 0.5rem 1.1rem;
    z-index: 10;
    transition: background 0.2s;
  }
  .san-btn:hover { background: rgba(0, 0, 0, 0.6); }
  .san-prev { left: 0; }
  .san-next { right: 0; }

  /* ── MIDDLE: 3-column info band ── */
  .san-mid {
    display: grid;
    grid-template-columns: 3fr 4fr calc((100% - 2 * 48px) / 3);
    gap: 48px;
    padding: 3rem var(--gutter);
    background: var(--black);
  }

.san-mid-center p {
    font-size: 14px;
    line-height: 1.8;
    color: var(--gray);
    text-align: justify;
  }

  .san-mid-center p + p {
    margin-top: 1rem;
  }

  .san-mid-right img {
    width: 100%;
    height: auto;
    display: block;
  }

  @media (max-width: 860px) {
    .san-mid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }

  /* ── BOTTOM: masonry gallery ── */
  .san-gallery-outer {
    padding: 0 4vw 6rem;
  }

  .san-masonry {
    position: relative;
  }

  .san-masonry img {
    position: absolute;
    display: block;
  }
</style>

<script>
  /* ── Carousel ── */
  const reel  = document.getElementById('sanReel')  as HTMLElement;
  const track = document.getElementById('sanTrack') as HTMLElement;

  const realCount = 4;
  const numClones = 2;
  let idx  = numClones;
  let busy = false;

  function slideWidths(): number[] {
    return Array.from(track.children).map(el => (el as HTMLElement).offsetWidth);
  }

  function posFor(n: number): number {
    const widths  = slideWidths();
    const slideW  = widths[n] ?? 0;
    const leftPad = (reel.offsetWidth - slideW) / 2;
    const offset  = widths.slice(0, n).reduce((s, w) => s + w, 0);
    return leftPad - offset;
  }

  function slideTo(n: number) {
    if (busy) return;
    busy = true;
    idx = n;
    track.style.transform = `translateX(${posFor(n)}px)`;
  }

  function jumpTo(n: number) {
    idx = n;
    track.style.transition = 'none';
    track.style.transform  = `translateX(${posFor(n)}px)`;
    void track.offsetWidth;
    track.style.transition = '';
  }

  const carouselImgs = Array.from(track.querySelectorAll('img')) as HTMLImageElement[];
  Promise.all(
    carouselImgs.map(img => img.complete
      ? Promise.resolve()
      : new Promise<void>(res => { img.onload = () => res(); img.onerror = () => res(); })
    )
  ).then(() => jumpTo(numClones));

  track.addEventListener('transitionend', () => {
    if (idx < numClones)                   jumpTo(idx + realCount);
    else if (idx >= numClones + realCount) jumpTo(idx - realCount);
    busy = false;
  });

  document.getElementById('sanPrev')?.addEventListener('click', () => slideTo(idx - 1));
  document.getElementById('sanNext')?.addEventListener('click', () => slideTo(idx + 1));

  window.addEventListener('resize', () => {
    track.style.transition = 'none';
    track.style.transform  = `translateX(${posFor(idx)}px)`;
    requestAnimationFrame(() => requestAnimationFrame(() => {
      track.style.transition = '';
    }));
  }, { passive: true });

  /* ── Masonry gallery ── */
  const GAP = 48;
  const masonry = document.getElementById('sanMasonry')!;
  const masonryImgs = Array.from(masonry.querySelectorAll('img')) as HTMLImageElement[];

  function numCols(): number {
    if (window.innerWidth <= 560) return 1;
    if (window.innerWidth <= 900) return 2;
    return 3;
  }

  function layoutMasonry() {
    const n      = numCols();
    const totalW = masonry.offsetWidth;
    const colW   = (totalW - (n - 1) * GAP) / n;

    const tops  = new Array<number>(n).fill(0);
    const lefts = Array.from({ length: n }, (_, i) => i * (colW + GAP));

    masonryImgs.forEach(img => {
      const iw   = parseInt(img.getAttribute('width')!);
      const ih   = parseInt(img.getAttribute('height')!);
      const imgH = colW * (ih / iw);

      let col = 0;
      for (let i = 1; i < n; i++) {
        if (tops[i] < tops[col]) col = i;
      }

      img.style.width  = colW + 'px';
      img.style.height = imgH + 'px';
      img.style.left   = lefts[col] + 'px';
      img.style.top    = tops[col]  + 'px';

      tops[col] += imgH + GAP;
    });

    masonry.style.height = (Math.max(...tops) - GAP) + 'px';
  }

  layoutMasonry();
  window.addEventListener('resize', layoutMasonry, { passive: true });
</script>

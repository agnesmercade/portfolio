---
import Layout from '../layouts/Layout.astro';

const CDN = "https://images.squarespace-cdn.com/content/v1/69788340c4a614347d63a918/";
const fmt = "?format=1500w";

const slides = [
  CDN + "4d7bb668-f145-4b96-b6e0-3f3c26fd59ba/A031342-R1-24-25A.jpg" + fmt,
  CDN + "2f52eeb6-96d4-470c-b461-454ee1f0ae3b/A031341-R1-33-35.jpg" + fmt,
  CDN + "29b4c846-f2c9-4e1a-af96-5fc9c6bdc2be/A031342-R1-22-23A.jpg" + fmt,
  CDN + "b2199425-a88e-493e-b541-44bad06d042f/A031341-R1-29-31.jpg" + fmt,
];

const row1 = [
  CDN + "aabf6805-5eb6-4587-b12a-e59ce93a37aa/PICT3598.JPG" + fmt,
  CDN + "1769513330379-CSD5MR0AA0HMST8URNKD/PICT3602.png" + fmt,
  CDN + "84c7ec12-1543-4fe3-8dce-497006e57347/PICT3599.JPG" + fmt,
  CDN + "8670b9b7-964d-451b-8ccc-4cefe8b63e3f/PICT3584.JPG" + fmt,
];

const row2 = [
  CDN + "85d2bc91-f931-4375-95b6-57298e509576/PICT3590.JPG" + fmt,
  CDN + "6ba49bfd-b5ef-4865-b71b-8a4a03a6af2b/PICT3592.JPG" + fmt,
  CDN + "73b80f2e-78c9-4c75-b692-487afe1204e0/PICT3593.JPG" + fmt,
  CDN + "bae3124b-0f49-4d34-8a47-e46a7e73dcce/A031341-R1-07-9.jpg" + fmt,
];

const row3 = [
  CDN + "cbdd75a5-30ef-46ef-b158-ae7f4f40b1f3/A031341-R1-18-20.jpg" + fmt,
  CDN + "35e747f1-38d1-41f2-bc99-79d5d5939d8c/A031341-R1-08-10.jpg" + fmt,
  CDN + "00779f14-7a33-42ce-abe8-58a6d93aad3f/A031341-R1-35-37.jpg" + fmt,
];

const row4 = [
  CDN + "4cd565cd-de33-4217-8148-2a8114dda8ba/PICT3597.JPG" + fmt,
  CDN + "5e6b6c58-352f-4f54-b6f9-7f8b176b0b51/PICT3604.JPG" + fmt,
];
---

<Layout title="Santander — Agnès Mercadé">

  <!-- Full-width carousel sits directly below the fixed nav -->
  <div class="san-top">
    <div class="san-reel" id="sanReel">
      <div class="san-track" id="sanTrack">
        <!-- 2 clones at start so the peek area stays filled when looping backward -->
        <div class="san-slide">
          <img src={slides[slides.length - 2]} alt="" />
        </div>
        <div class="san-slide">
          <img src={slides[slides.length - 1]} alt="" />
        </div>
        {slides.map(src => (
          <div class="san-slide">
            <img src={src} alt="" />
          </div>
        ))}
        <!-- 2 clones at end so the peek area stays filled when looping forward -->
        <div class="san-slide">
          <img src={slides[0]} alt="" />
        </div>
        <div class="san-slide">
          <img src={slides[1]} alt="" />
        </div>
      </div>
      <button class="san-btn san-prev" id="sanPrev" aria-label="Previous">&#8249;</button>
      <button class="san-btn san-next" id="sanNext" aria-label="Next">&#8250;</button>
    </div>
  </div>

  <!-- Title, description, grid (reduced top padding since carousel is above) -->
  <section class="project-detail san-detail">
    <h1>Santander</h1>
    <div class="project-description">
      <p>A personal project shot on 35mm film in Santander, combining color and black and white.</p>
      <p>
        The black and white images come from an intentional experiment during development: the film
        was treated as if it had been shot at a lower ISO, pushing contrast and density further.
        The result is a more graphic and defined look, where light and shadow take the lead.
      </p>
      <p>
        Color photographs work differently, paying attention to subtle shifts in light, atmosphere,
        and balance within the frame.
      </p>
      <p>
        Across both formats, the project is driven by visual intuition and a strong sense of
        composition, rather than a fixed narrative.
      </p>
    </div>

    <div class="gallery-section">
      <div class="project-gallery cols-4">
        {row1.map(src => <img src={src} alt="" loading="lazy" />)}
      </div>
    </div>

    <div class="gallery-section">
      <div class="project-gallery cols-4">
        {row2.map(src => <img src={src} alt="" loading="lazy" />)}
      </div>
    </div>

    <div class="gallery-section">
      <div class="project-gallery cols-3">
        {row3.map(src => <img src={src} alt="" loading="lazy" />)}
      </div>
    </div>

    <div class="gallery-section">
      <div class="project-gallery cols-2">
        {row4.map(src => <img src={src} alt="" loading="lazy" />)}
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ── Carousel wrapper: pushes below fixed nav ── */
  .san-top {
    padding-top: var(--nav-height);
    background: #000;
  }

  /* ── Reel: fixed height, clips slides outside its bounds ── */
  .san-reel {
    position: relative;
    overflow: hidden;
    width: 100%;
    height: clamp(280px, 60vh, 640px);
  }

  /* ── Track: flex row, full reel height, no gap so images touch ── */
  .san-track {
    display: flex;
    height: 100%;
    transition: transform 0.5s ease;
    will-change: transform;
  }

  /* ── Each slide: width = image's natural aspect ratio × reel height ── */
  .san-slide {
    flex-shrink: 0;
    height: 100%;
  }

  .san-slide img {
    height: 100%;
    width: auto;
    display: block;
  }

  /* ── Prev / Next arrows ── */
  .san-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(0, 0, 0, 0.3);
    border: none;
    color: #fff;
    font-size: 2.5rem;
    line-height: 1;
    cursor: pointer;
    padding: 0.5rem 1.1rem;
    z-index: 10;
    transition: background 0.2s;
  }
  .san-btn:hover { background: rgba(0, 0, 0, 0.6); }
  .san-prev { left: 0; }
  .san-next { right: 0; }

  /* ── Project detail: less top padding since carousel fills that space ── */
  .san-detail {
    padding-top: 3rem;
  }

  /* ── Grid: larger gap and uniform 3:2 cells ── */
  .project-gallery {
    gap: 8px;
  }

  .gallery-section + .gallery-section {
    margin-top: 8px;
  }

  .project-gallery img {
    aspect-ratio: 3 / 2;
    width: 100%;
    height: auto;
    object-fit: cover;
    display: block;
  }
</style>

<script>
  const reel  = document.getElementById('sanReel')  as HTMLElement;
  const track = document.getElementById('sanTrack') as HTMLElement;

  const realCount = 4;
  const numClones = 2; // clones on each end
  // DOM: [cln2, cln3, slide0, slide1, slide2, slide3, cln0, cln1]  (indices 0-7)
  let idx  = numClones; // start at first real slide
  let busy = false;

  /** Slide widths may differ per image aspect ratio — read them fresh each time */
  function slideWidths(): number[] {
    return Array.from(track.children).map(el => (el as HTMLElement).offsetWidth);
  }

  /** translateX that centres slide n, accounting for variable widths */
  function posFor(n: number): number {
    const widths  = slideWidths();
    const slideW  = widths[n] ?? 0;
    const leftPad = (reel.offsetWidth - slideW) / 2;
    const offset  = widths.slice(0, n).reduce((s, w) => s + w, 0);
    return leftPad - offset;
  }

  /** Animated move to position n */
  function slideTo(n: number) {
    if (busy) return;
    busy = true;
    idx = n;
    track.style.transform = `translateX(${posFor(n)}px)`;
  }

  /** Instant (no-animation) jump — used for the infinite-loop snap */
  function jumpTo(n: number) {
    idx = n;
    track.style.transition = 'none';
    track.style.transform  = `translateX(${posFor(n)}px)`;
    void track.offsetWidth;
    track.style.transition = '';
  }

  // Wait for images to have natural dimensions before positioning
  const imgs = Array.from(track.querySelectorAll('img')) as HTMLImageElement[];
  Promise.all(
    imgs.map(img => img.complete
      ? Promise.resolve()
      : new Promise<void>(res => { img.onload = () => res(); img.onerror = () => res(); })
    )
  ).then(() => jumpTo(numClones));

  // After each animated transition, snap from clone zone back to real slides
  track.addEventListener('transitionend', () => {
    if (idx < numClones)                    jumpTo(idx + realCount);
    else if (idx >= numClones + realCount)  jumpTo(idx - realCount);
    busy = false;
  });

  document.getElementById('sanPrev')?.addEventListener('click', () => slideTo(idx - 1));
  document.getElementById('sanNext')?.addEventListener('click', () => slideTo(idx + 1));

  // Reposition without animation on resize so layout stays correct
  window.addEventListener('resize', () => {
    track.style.transition = 'none';
    track.style.transform  = `translateX(${posFor(idx)}px)`;
    requestAnimationFrame(() => requestAnimationFrame(() => {
      track.style.transition = '';
    }));
  }, { passive: true });
</script>

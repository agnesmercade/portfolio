---
import Layout from '../layouts/Layout.astro';
import { asset } from '../utils/url';

// 9 images matching the reference layout (mix of Santander + Echoes of Comfort)
const images = [
  { href: asset('/santander'),         src: asset('/images/santander/carousel-1.jpg') },
  { href: asset('/santander'),         src: asset('/images/santander/gallery-03.jpg') },
  { href: asset('/santander'),         src: asset('/images/santander/gallery-08.jpg') },
  { href: asset('/echoes-of-comfort'), src: asset('/images/echoes/03.jpg') },
  { href: asset('/santander'),         src: asset('/images/santander/carousel-2.jpg') },
  { href: asset('/santander'),         src: asset('/images/home/gallery-06.jpg') },
  { href: asset('/echoes-of-comfort'), src: asset('/images/echoes/01.jpg') },
  { href: asset('/echoes-of-comfort'), src: asset('/images/echoes/02.jpg') },
  { href: asset('/santander'),         src: asset('/images/santander/gallery-04.jpg') },
];
---

<Layout title="Agnès Mercadé">
  <section class="hero">
    <div class="hero-content">
      <p class="hero-tagline" data-i18n="home.tagline">Creative. Intuitive. Intentional. Visual.</p>
      <p class="hero-sub" data-i18n="home.sub">Work across image, digital marketing and video.</p>
    </div>
  </section>

  <div id="homeGallery">
    {images.map(item => (
      <a href={item.href} class="gal-item">
        <img src={item.src} alt="" />
      </a>
    ))}
  </div>
</Layout>

<style is:global>
  #homeGallery {
    background: #000;
    padding: 0 var(--gutter) 6rem;
    /* Fallback column layout before JS */
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  /* Fallback: stacked full-width strips */
  #homeGallery > .gal-item {
    display: block;
    width: 100%;
    height: 200px;
    overflow: hidden;
  }

  /* JS-created row containers */
  #homeGallery .gal-row {
    display: flex;
    flex-direction: row;
    gap: 8px;
    overflow: hidden;
    flex-shrink: 0;
  }

  /* Items inside rows */
  #homeGallery .gal-row .gal-item {
    display: block;
    overflow: hidden;
    flex-shrink: 0;
    min-width: 0;
  }

  #homeGallery .gal-item img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.65s ease;
  }

  #homeGallery .gal-item:hover img {
    transform: scale(1.03);
  }
</style>

<script>
  const GAP = 8;

  function layout() {
    const gallery = document.getElementById('homeGallery');
    if (!gallery) return;

    const items = Array.from(gallery.querySelectorAll('.gal-item')) as HTMLElement[];
    if (!items.length) return;

    const cs = getComputedStyle(gallery);
    const W = gallery.offsetWidth - parseFloat(cs.paddingLeft) - parseFloat(cs.paddingRight);
    if (!W) return;

    // Aspect ratios (fallback 3:2 if image not yet loaded)
    const ratios = items.map(el => {
      const img = el.querySelector('img') as HTMLImageElement;
      return img?.naturalWidth && img?.naturalHeight
        ? img.naturalWidth / img.naturalHeight
        : 1.5;
    });

    const n = items.length;

    const vw = window.innerWidth;

    // Single column on small phones — use viewport width so padding doesn't skew the check
    if (vw < 768) {
      gallery.innerHTML = '';
      gallery.style.cssText = 'display:flex;flex-direction:column;gap:8px;background:#000;';
      items.forEach(el => {
        // height:auto overrides the CSS fallback (200px) so aspect ratio is preserved
        el.style.cssText = 'display:block;width:100%;height:auto;overflow:hidden;';
        const img = el.querySelector('img') as HTMLImageElement | null;
        if (img) img.style.cssText = 'width:100%;height:auto;display:block;transition:transform 0.65s ease;';
        gallery.appendChild(el);
      });
      return;
    }

    // Justified rows.
    // Math.floor keeps nRows conservative so the last row is never a lone image.
    // Breakpoints: <768 single-col | 768-1023 ~2/row | 1024-1340 ~3/row | 1341+ ~4-5/row
    const targetPerRow = vw >= 1341 ? 4.5 : vw >= 1024 ? 3 : 2;
    const nRows = Math.max(1, Math.floor(n / targetPerRow));

    // Partition by image count (floor(n/nRows) per row) so the number of images per row
    // matches the target regardless of aspect ratios. The last row absorbs the remainder.
    const imgsPerRow = Math.floor(n / nRows);
    type Entry = { el: HTMLElement; ratio: number };
    const rows: Entry[][] = [];
    let cur: Entry[] = [];

    for (let i = 0; i < n; i++) {
      cur.push({ el: items[i], ratio: ratios[i] });
      if (cur.length >= imgsPerRow && rows.length < nRows - 1) {
        rows.push(cur);
        cur = [];
      }
    }
    if (cur.length) rows.push(cur);

    // Safety: lone last image → borrow one from previous row
    if (rows.length > 1 && rows[rows.length - 1].length === 1 && rows[rows.length - 2].length > 1) {
      rows[rows.length - 1].unshift(rows[rows.length - 2].pop()!);
    }

    // Rebuild DOM
    gallery.innerHTML = '';
    gallery.style.cssText = 'display:flex;flex-direction:column;gap:8px;background:#000;';

    rows.forEach(row => {
      const totalR = row.reduce((s, x) => s + x.ratio, 0);
      const rowH = (W - GAP * (row.length - 1)) / totalR;

      const rowDiv = document.createElement('div');
      rowDiv.className = 'gal-row';
      rowDiv.style.cssText = `display:flex;flex-direction:row;gap:${GAP}px;height:${rowH}px;width:100%;overflow:hidden;flex-shrink:0;`;

      row.forEach(({ el, ratio }) => {
        el.style.cssText = `flex-grow:${ratio};flex-basis:0;flex-shrink:0;height:${rowH}px;overflow:hidden;display:block;min-width:0;`;
        const img = el.querySelector('img') as HTMLImageElement | null;
        if (img) img.style.cssText = 'width:100%;height:100%;object-fit:cover;display:block;transition:transform 0.65s ease;';
        rowDiv.appendChild(el);
      });

      gallery.appendChild(rowDiv);
    });
  }

  function init() {
    const gallery = document.getElementById('homeGallery');
    if (!gallery) return;

    const imgs = Array.from(gallery.querySelectorAll('img')) as HTMLImageElement[];
    let loaded = 0;
    const check = () => { if (++loaded >= imgs.length) layout(); };

    imgs.forEach(img => {
      if (img.complete && img.naturalWidth) check();
      else {
        img.addEventListener('load', check, { once: true });
        img.addEventListener('error', check, { once: true });
      }
    });

    let t: ReturnType<typeof setTimeout>;
    window.addEventListener('resize', () => {
      clearTimeout(t);
      t = setTimeout(layout, 80);
    }, { passive: true });
  }

  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
  else init();
</script>

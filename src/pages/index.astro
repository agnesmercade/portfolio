---
import Layout from '../layouts/Layout.astro';
import { asset } from '../utils/url';

const images = [
  { href: asset('/santander'),         src: asset('/images/santander/gallery-03.jpg'), w: 960,  h: 640  },
  { href: asset('/santander'),         src: asset('/images/santander/carousel-1.jpg'), w: 1600, h: 2385 },
  { href: asset('/santander'),         src: asset('/images/santander/gallery-08.jpg'), w: 960,  h: 644  },
  { href: asset('/echoes-of-comfort'), src: asset('/images/echoes/03.jpg'),            w: 1000, h: 1482 },
  { href: asset('/santander'),         src: asset('/images/santander/carousel-2.jpg'), w: 1600, h: 1073 },
  { href: asset('/santander'),         src: asset('/images/home/gallery-06.jpg'),      w: 960,  h: 1440 },
  { href: asset('/echoes-of-comfort'), src: asset('/images/echoes/01.jpg'),            w: 1000, h: 1487 },
  { href: asset('/echoes-of-comfort'), src: asset('/images/echoes/02.jpg'),            w: 1000, h: 672  },
  { href: asset('/santander'),         src: asset('/images/santander/gallery-04.jpg'), w: 960,  h: 640  },
];
---

<Layout title="Agnès Mercadé">
  <section class="hero">
    <div class="hero-content">
      <p class="hero-tagline" data-i18n="home.tagline">Creative. Intuitive. Intentional. Visual.</p>
      <p class="hero-sub" data-i18n="home.sub">Work across image, digital marketing and video.</p>
    </div>
  </section>

  <div id="homeGallery">
    {images.map(item => (
      <a href={item.href} class="gal-item">
        <img src={item.src} alt="" width={item.w} height={item.h} />
      </a>
    ))}
  </div>
</Layout>

<style is:global>
  #homeGallery {
    background: #000;
    padding: 0 var(--gutter) 6rem;
    /* Fallback column layout before JS */
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  /* Fallback: stacked full-width strips */
  #homeGallery > .gal-item {
    display: block;
    width: 100%;
    height: 200px;
    overflow: hidden;
  }

  /* JS-created row containers */
  #homeGallery .gal-row {
    display: flex;
    flex-direction: row;
    gap: 8px;
    overflow: hidden;
    flex-shrink: 0;
  }

  /* Items inside rows */
  #homeGallery .gal-row .gal-item {
    display: block;
    overflow: hidden;
    flex-shrink: 0;
    min-width: 0;
  }

  #homeGallery .gal-item img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.65s ease;
  }

  #homeGallery .gal-item:hover img {
    transform: scale(1.03);
  }
</style>

<script>
  const GAP = 8;

  function layout() {
    const gallery = document.getElementById('homeGallery');
    if (!gallery) return;

    const items = Array.from(gallery.querySelectorAll('.gal-item')) as HTMLElement[];
    if (!items.length) return;

    const cs = getComputedStyle(gallery);
    const W = gallery.offsetWidth - parseFloat(cs.paddingLeft) - parseFloat(cs.paddingRight);
    if (!W) return;

    // Aspect ratios from width/height attributes (accurate before load)
    const ratios = items.map(el => {
      const img = el.querySelector('img') as HTMLImageElement;
      const attrW = parseInt(img?.getAttribute('width') || '0');
      const attrH = parseInt(img?.getAttribute('height') || '0');
      if (attrW && attrH) return attrW / attrH;
      return img?.naturalWidth && img?.naturalHeight
        ? img.naturalWidth / img.naturalHeight
        : 1.5;
    });

    const vw = window.innerWidth;

    // Single column on small phones
    if (vw < 768) {
      gallery.innerHTML = '';
      gallery.style.cssText = 'display:flex;flex-direction:column;gap:8px;background:#000;';
      items.forEach(el => {
        el.style.cssText = 'display:block;width:100%;height:auto;overflow:hidden;';
        const img = el.querySelector('img') as HTMLImageElement | null;
        if (img) img.style.cssText = 'width:100%;height:auto;display:block;transition:transform 0.65s ease;';
        gallery.appendChild(el);
      });
      return;
    }

    // Fixed row distribution: 3 | 4 | 2
    const rowSizes = [3, 4, 2];
    type Entry = { el: HTMLElement; ratio: number };
    const rows: Entry[][] = [];
    let offset = 0;
    for (const size of rowSizes) {
      rows.push(
        items.slice(offset, offset + size).map((el, i) => ({ el, ratio: ratios[offset + i] }))
      );
      offset += size;
    }

    // Rebuild DOM
    gallery.innerHTML = '';
    gallery.style.cssText = 'display:flex;flex-direction:column;gap:8px;background:#000;';

    rows.forEach(row => {
      const totalR = row.reduce((s, x) => s + x.ratio, 0);
      const rowH = (W - GAP * (row.length - 1)) / totalR;

      const rowDiv = document.createElement('div');
      rowDiv.className = 'gal-row';
      rowDiv.style.cssText = `display:flex;flex-direction:row;gap:${GAP}px;height:${rowH}px;width:100%;overflow:hidden;flex-shrink:0;`;

      row.forEach(({ el, ratio }) => {
        el.style.cssText = `flex-grow:${ratio};flex-basis:0;flex-shrink:0;height:${rowH}px;overflow:hidden;display:block;min-width:0;`;
        const img = el.querySelector('img') as HTMLImageElement | null;
        if (img) img.style.cssText = 'width:100%;height:100%;object-fit:cover;display:block;transition:transform 0.65s ease;';
        rowDiv.appendChild(el);
      });

      gallery.appendChild(rowDiv);
    });
  }

  function init() {
    const gallery = document.getElementById('homeGallery');
    if (!gallery) return;

    const imgs = Array.from(gallery.querySelectorAll('img')) as HTMLImageElement[];
    let loaded = 0;
    const check = () => { if (++loaded >= imgs.length) layout(); };

    imgs.forEach(img => {
      if (img.complete && img.naturalWidth) check();
      else {
        img.addEventListener('load', check, { once: true });
        img.addEventListener('error', check, { once: true });
      }
    });

    let t: ReturnType<typeof setTimeout>;
    window.addEventListener('resize', () => {
      clearTimeout(t);
      t = setTimeout(layout, 80);
    }, { passive: true });
  }

  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
  else init();
</script>

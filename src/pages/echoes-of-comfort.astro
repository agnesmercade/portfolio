---
import Layout from '../layouts/Layout.astro';

const CDN = "https://images.squarespace-cdn.com/content/v1/69788340c4a614347d63a918/";
const fmt = "?format=1500w";

const images = [
  CDN + "6b385efd-0bdb-4f78-9074-1d28e2c0469d/llabiafinal-004.jpg" + fmt,
  CDN + "a2432303-900b-43b7-a383-006bbf200aa2/llabiafinal-002.jpg" + fmt,
  CDN + "1076f59d-8d65-41f2-94f3-8cbadf4ac880/llabiafinal-024.jpg" + fmt,
  CDN + "6a5d62a1-753c-4b39-b618-bfea05f8a376/llabiafinal-021.jpg" + fmt,
  CDN + "b09eb36b-2951-4d1f-a4c9-48d67027dbfe/llabiafinal-006.jpg" + fmt,
  CDN + "9ab0e4ae-6ebd-47d3-954e-075a5e05cf6d/llabiafinal-003.jpg" + fmt,
  CDN + "e8bd4a3a-e834-47a1-8951-1a8c47ce5126/llabiafinal-028.jpg" + fmt,
  CDN + "b1bd2fad-028d-47d8-a884-9e6c74c29d3f/llabiafinal-005.jpg" + fmt,
];
---

<Layout title="Echoes of Comfort — Agnès Mercadé">
  <section class="project-detail">
    <h1>Echoes of Comfort</h1>
    <div class="project-description">
      <p>This project was developed as my final year major project during my BA in Photography.</p>
      <p>
        It was born from a desire to express a sense of nostalgia, peacefulness, and happiness
        that I feel when I am in the places photographed. It is a reminiscence of the open,
        vibrant fields I have grown up with and been surrounded by throughout my life, translated
        into images that feel warm, homely, and serene.
      </p>
      <p>
        Through this work, I explore quieter, yet equally captivating, rural landscapes, offering
        a slower and more intimate perspective of Spain, a country often associated with its vibrant
        and active cities.
      </p>
      <p>
        The title suggests a subtle connection between place and memory, reflecting the blend of
        coastal and rural landscapes of the Costa Brava in northeastern Spain, where the work was
        photographed. There are no literal echoes, but a lingering sense of reminiscence shaped by
        familiarity and comfort in these surroundings.
      </p>
    </div>

    <div class="project-gallery cols-1">
      {images.map(src => (
        <img src={src} alt="" loading="lazy" />
      ))}
    </div>
  </section>
</Layout>

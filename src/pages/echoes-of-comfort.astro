---
import Layout from '../layouts/Layout.astro';
import { asset } from '../utils/url';

const images = [
  { src: asset('/images/echoes/01.jpg'), w: 3550, h: 5280 },
  { src: asset('/images/echoes/02.jpg'), w: 5280, h: 3546 },
  { src: asset('/images/echoes/03.jpg'), w: 3562, h: 5280 },
  { src: asset('/images/echoes/04.jpg'), w: 5280, h: 3572 },
  { src: asset('/images/echoes/05.jpg'), w: 5280, h: 3547 },
  { src: asset('/images/echoes/06.jpg'), w: 3542, h: 5280 },
  { src: asset('/images/echoes/07.jpg'), w: 5280, h: 3568 },
  { src: asset('/images/echoes/08.jpg'), w: 5280, h: 3525 },
];
---

<Layout title="Echoes of Comfort — Agnès Mercadé">

  <section class="project-detail eoc-detail">
    <h1>Echoes of Comfort</h1>
    <div class="project-description">
      <p data-i18n="eoc.p1">This project was developed as my final year major project during my BA in Photography.</p>
      <p data-i18n="eoc.p2">
        It was born from a desire to express a sense of nostalgia, peacefulness, and happiness
        that I feel when I am in the places photographed. It is a reminiscence of the open,
        vibrant fields I have grown up with and been surrounded by throughout my life, translated
        into images that feel warm, homely, and serene.
      </p>
      <p data-i18n="eoc.p3">
        Through this work, I explore quieter, yet equally captivating, rural landscapes, offering
        a slower and more intimate perspective of Spain, a country often associated with its vibrant
        and active cities.
      </p>
      <p data-i18n="eoc.p4">
        The title suggests a subtle connection between place and memory, reflecting the blend of
        coastal and rural landscapes of the Costa Brava in northeastern Spain, where the work was
        photographed. There are no literal echoes, but a lingering sense of reminiscence shaped by
        familiarity and comfort in these surroundings.
      </p>
    </div>
  </section>

  <!-- outer div carries the padding; inner div is the masonry canvas -->
  <div class="eoc-outer">
    <div class="eoc-masonry" id="eocMasonry">
      {images.map(({ src, w, h }) => (
        <img src={src} alt="" loading="lazy" width={w} height={h} />
      ))}
    </div>
  </div>

</Layout>

<style>
  .eoc-detail {
    padding-bottom: 0;
  }

  .eoc-outer {
    padding: 3rem 4vw 6rem;
  }

  /* position: relative canvas; JS sets absolute positions + explicit height */
  .eoc-masonry {
    position: relative;
  }

  .eoc-masonry img {
    position: absolute;
    display: block;
    /* width + top + left set by JS */
  }
</style>

<script>
  const GAP = 25;
  const container = document.getElementById('eocMasonry')!;
  const imgs = Array.from(container.querySelectorAll('img')) as HTMLImageElement[];

  function numCols(): number {
    if (window.innerWidth <= 560) return 1;
    if (window.innerWidth <= 900) return 2;
    return 3;
  }

  function layout() {
    const n      = numCols();
    const totalW = container.offsetWidth;
    const colW   = (totalW - (n - 1) * GAP) / n;

    const tops   = new Array<number>(n).fill(0);
    const lefts  = Array.from({ length: n }, (_, i) => i * (colW + GAP));

    imgs.forEach(img => {
      const iw = parseInt(img.getAttribute('width')!);
      const ih = parseInt(img.getAttribute('height')!);
      const imgH = colW * (ih / iw);

      // shortest-column placement
      let col = 0;
      for (let i = 1; i < n; i++) {
        if (tops[i] < tops[col]) col = i;
      }

      img.style.width  = colW + 'px';
      img.style.height = imgH + 'px';
      img.style.left   = lefts[col] + 'px';
      img.style.top    = tops[col]  + 'px';

      tops[col] += imgH + GAP;
    });

    // set canvas height so the outer div knows how tall to be
    container.style.height = (Math.max(...tops) - GAP) + 'px';
  }

  layout();
  window.addEventListener('resize', layout, { passive: true });
</script>
